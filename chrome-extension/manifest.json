{
  "manifest_version": 3,
  "name": "Cyberbullying Watch - WhatsApp Helper",
  "description": "Send WhatsApp Web outgoing messages with chat name to the local ingest server.",
  "version": "0.0.1",
  "permissions": [],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1:4820/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

